imap jj <Esc>¬
let g:ctrlp_custom_ignore = {
  \ 'dir':  '\.git$\|\.hg$\|\.svn$\|\.yardoc$|target$|build$',
  \ 'file': '\.exe$\|\.so$\|\.dat$|\.jar$|\.class$|\.orig$'
