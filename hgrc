[extensions]
rebase=
hgext.convert=
hgext.extdiff =
#onsub = ~/.mercurial/onsub.py
shelve=
graphlog=
color=
pager=
mq=
#hgsubversion = ~/.hg/hgsubversion/hgsubversion
hgext.purge=
progress=
convert=
#prompt = ~/.mercurial/prompt.py
mercurial_keyring = 

[color]
custom.rev = bold
custom.author = blue
custom.date = green

[alias]
clog = glog --style compact
spull = pull -u
cls = up -C
mlog = log --stat | less 
lglimit_short= log --limit 1 --template "{label('custom.rev',rev)}:{label('custom.rev',node|short)} ({branch}) \n"
lglimit= log --limit $1 --template "{rev}:{label('custom.rev',node|short)}:[{branch}] - {desc|strip|firstline} <{label('custom.author',author|user)}> {label('custom.date',date|isodate)}\n"
lg = lglimit 10
lgt = lglimit 1
lgb=lglimit 10 -b $1
lgall = lglimit 10000000000 
br = branch
brs = branches
bt = lg --limit 1 -b $1
bts = lglimit_short -b $1
btip = bt $1
sw = up -C $1
switch = sw $1
closebr = ci --close-branch -m 'DEV-000: Closed merged branch'
close_obsolete = ci --close-branch -m 'Closing obsolete or outdated branch'
untrack = rm -Af
sync = !$HG spull; hg push
merge_fb = !$HG merge $1 && hg ci -m $2 && hg sw $1 && hg closebr && hg sw default
changes=status -m
extra=status -u -n
missing=status -r -d -n
st=status
father = lg -r "parents(min(branch('$1')))"

[pager]
pager = LESS='FRX' less

[extdiff]
cmd.diffmerge = /usr/local/bin/diffmerge
cmd.examdiff = /usr/local/bin/diffmerge
cmd.vimdiff =
cmd.p4 = /Applications/p4merge.app/Contents/MacOS/p4merge 
cmd.opendiff = opendiff-w

[merge-tools]
diffmerge.executable = /usr/local/bin/diffmerge
diffmerge.args = -merge -result=$output -t1="Local Version" -t2=$output -t3="Other Version" -caption=$output $local $base $other
diffmerge.binary = False
diffmerge.symlinks = False
diffmerge.gui = True
vimdiff.executable = vim
vimdiff.args = -d -c "wincmd J" "$output" "$local" "$other" "$base"
p4.priority = 60
p4.premerge = True
p4.executable = /Applications/p4merge.app/Contents/MacOS/p4merge
p4.gui = True
p4.args = $base $local $other $output
p4.binary = False

[ui]
ssh = ssh -C
#merge = p4
merge = diffmerge
#merge = vimdiff
editor = vim
style=compact
username=Timoteo Ponce <ponce.timoteo@gmail.com>

