[alias]
  ci = commit
  co = checkout
  df = diff
  br = branch
  st =  status -s -b
  stat = status -s -b
  checkout = co
  lg = log -n 10 --graph --pretty=format:'%Cred%h%Creset%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
  ls = ls-files --modified
  addmod = !git ls-files --modified | xargs git add
  addrm = !git ls-files --deleted | xargs git rm
  #addrm = !git addmod & git addextra & git addrm
  addextra = !git ls-files -o | xargs git add
  webui = !/Users/timoteo/.git-webui/release/libexec/git-core/git-webui
  changes = ls-files --modified
  extra = ls-files --others
  cached = ls-files --cached
  staged = ls-files --stage
  missing = ls-files --deleted
  # aliases that match the hg in / out commands
  out      = !git fetch && git log FETCH_HEAD..
  outgoing = !git fetch && git log FETCH_HEAD..
  in       = !git fetch && git log ..FETCH_HEAD
  incoming = !git fetch && git log ..FETCH_HEAD
  pushH = push origin HEAD
  pullH = pull origin HEAD

[color]
  ui = auto
  diff = auto
  status = auto
  branch = auto

[core]
  pager = less -FXRS
  editor = vim
	excludesfile = /Users/timoteo/.gitignore_global

[user]
  name = Timoteo Ponce
	email = timo.slack@gmail.com

[diff]
  tool = diffmerge

[difftool "diffmerge"]
  cmd = /usr/local/bin/diffmerge \"$LOCAL\" \"$REMOTE\"

[merge]
  tool = diffmerge

[mergetool "diffmerge"]
  cmd = "diffmerge --merge --result=\"$MERGED\" \"$LOCAL\" \"$(if test -f \"$BASE\"; then echo \"$BASE\"; else echo \"$LOCAL\"; fi)\" \"$REMOTE\""
  trustExitCode = true

[webui]
  autoupdate = true
[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path =
[mergetool "sourcetree"]
	cmd = /Applications/SourceTree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
[credential]
	helper = osxkeychain
