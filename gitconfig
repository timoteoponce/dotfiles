[alias]
  ci = commit
  co = checkout
  df = diff
  br = branch
  st =  status -s -b
  stat = status -s -b
  checkout = co
  lg = log -n 10 --graph --pretty=format:'%Cred%h%Creset%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
  ls = ls-files --modified
  changes = ls-files --modified
  extra = ls-files --others
  cached = ls-files --cached
  staged = ls-files --stage
  missing = ls-files --deleted
  prune= "git remote prune origin && git fetch -p"

[color]
  ui = auto
  diff = auto
  status = auto
  branch = auto

[core]
  pager = less -FXRS
  editor = vim
  excludesfile = /Users/timoteo/.gitignore_global
  autocrlf = input

[user]
  name = Timoteo Ponce
  email = ponce.timoteo@gmail.com

[credential]
  helper = store
[pull]
  rebase = false
[init]
  defaultBranch = main
[mergetool]
  prompt = true
  keepBackup = false
[difftool]
  prompt = true
[fetch]
  prune = true
