[alias]
  ci = commit
  co = checkout
  df = diff
  br = branch
  st =  status -s -b
  stat = status -s -b
  checkout = co
  lg = log -n 10 --graph --pretty=format:'%Cred%h%Creset%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
  ls = ls-files --modified
  changes = ls-files --modified
  extra = ls-files --others
  cached = ls-files --cached
  staged = ls-files --stage
  missing = ls-files --deleted
  prune= "git remote prune origin && git fetch -p"
  gone = "!f() { git fetch --all --prune; git branch -vv | awk '/: gone]/{print $1}' | xargs git branch -D; }; f"

[color]
  ui = auto
  diff = auto
  status = auto
  branch = auto

[core]
  pager = less -FXRS
  editor = vim
	excludesFile = ~/.gitignore
  autocrlf = input
	quotepath = false

[user]
  name = Timoteo Ponce
  email = ponce.timoteo@gmail.com

[credential]
	helper = /usr/local/share/gcm-core/git-credential-manager
[pull]
  rebase = false
[init]
  defaultBranch = main
[mergetool]
  prompt = true
  keepBackup = false
[difftool]
  prompt = true
[fetch]
  prune = true
[diff]
	tool = diffmerge
	algorithm = histogram
	; tool = vimdiff
[merge]
	tool = diffmerge
	; tool = vimdiff
  conflictstyle = diff3
[push]
	autoSetupRemote = true
[difftool "diffmerge"]
	cmd = /usr/local/bin/diffmerge \"$LOCAL\" \"$REMOTE\"
[mergetool "diffmerge"]
	trustExitCode = true
	cmd = /usr/local/bin/diffmerge --merge --result=\"$MERGED\" \"$LOCAL\" \"$BASE\" \"$REMOTE\"
[credential "https://dev.azure.com"]
	useHttpPath = true
[credential "http://localhost:3000"]
	provider = generic
[gpg]
	format = ssh
[maintenance]
	repo = /Users/timoteo/projects/confinale/aspark-demo-adapter
