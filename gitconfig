[alias]
  ci = commit
  co = checkout
  df = diff
  br = branch
  st =  status -s -b
  stat = status -s -b
  checkout = co
  lg = log -n 10 --graph --pretty=format:'%Cred%h%Creset%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
  ls = ls-files --modified
  changes = ls-files --modified
  extra = ls-files --others
  cached = ls-files --cached
  staged = ls-files --stage
  missing = ls-files --deleted
  prune= "git remote prune origin && git fetch -p"
  gone = "!f() { git fetch --all --prune; git branch -vv | awk '/: gone]/{print $1}' | xargs git branch -D; }; f"

[color]
  ui = auto
  diff = auto
  status = auto
  branch = auto

[core]
  pager = less -FXRS
  ; pager = delta
  editor = nvim
	excludesFile = ~/.gitignore
  autocrlf = input
	quotepath = false

[interactive]
  diffFilter = delta --color-only

[user]
  name = Timoteo Ponce
[pull]
  rebase = false
[init]
	defaultBranch = main
[mergetool]
  prompt = true
  keepBackup = false
[difftool]
  prompt = true
[fetch]
	prune = true
	pruneTags = true
	all = true
[diff]
	tool = vimdiff
	algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true
	renames = true
	; algorithm = histogram
	; tool = diffmerge
[merge]
	tool = vimdiff
	; tool = diffmerge
	conflictstyle = zdiff3
[push]
	autoSetupRemote = true
	default = simple
	followTags = true
[credential]
	helper = 
	helper = /usr/local/share/gcm-core/git-credential-manager
[credential "https://dev.azure.com"]
	useHttpPath = true
[column]
	ui = auto
[branch]
	sort = -committerdate
[tag]
	sort = version:refname
[help]
	autocorrect = prompt

